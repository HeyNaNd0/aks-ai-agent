# ── Secrets — NEVER commit these ──────────────────────────
.env
*.pem
*.key
*.pfx
kubeconfig
.kube/

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ── Virtual environments ──────────────────────────────────
venv/
.venv/
env/
.env/

# ── Testing & coverage ────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# ── Data & logs (generated at runtime) ───────────────────
data/
logs/
*.db
*.db-shm
*.db-wal

# ── IDE ───────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# ── Docker ────────────────────────────────────────────────
.dockerignore
