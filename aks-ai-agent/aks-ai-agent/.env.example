# ============================================================
# AKS AI Agent — Required Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env — it's in .gitignore
# In production: use GitHub Secrets or Azure Key Vault
# ============================================================

# ── Anthropic (Claude AI) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Azure Service Principal ───────────────────────────────────
# Create with: az ad sp create-for-rbac --name "aks-ai-agent" --role Contributor
#              --scopes /subscriptions/<SUB_ID>/resourceGroups/<RG>
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-here

# ── Email (Gmail example) ─────────────────────────────────────
# For Gmail: create an App Password at myaccount.google.com/apppasswords
ADMIN_EMAIL_PASSWORD=your-app-password-here

# ── GitHub ────────────────────────────────────────────────────
# Create at github.com/settings/tokens — needs repo + issues scopes
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Kubernetes ────────────────────────────────────────────────
# Leave empty if running inside the cluster (uses service account)
# Set to file path for local development
KUBECONFIG=/path/to/.kube/config

# ── Agent config ──────────────────────────────────────────────
AKS_AGENT_CONFIG=config/config.yaml
